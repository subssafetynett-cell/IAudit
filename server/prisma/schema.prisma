// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id             Int      @id @default(autoincrement())
  name           String
  logo           String?
  industry       String?
  contactNumber  String?
  description    String?
  streetAddress  String?
  city           String?
  state          String?
  country        String?
  postalCode     String?
  isoStandards   String[] @default([])
  location       String?  // Keeping for backward compatibility or as a summary
  contactDetails String?  // Keeping for backward compatibility or as a summary
  userId         Int?
  user           User?    @relation("UserCompanies", fields: [userId], references: [id])
  sites          Site[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Site {
  id              Int          @id @default(autoincrement())
  name            String
  description     String?
  siteType        String?
  status          String?      @default("Active")
  address         String?
  city            String?
  state           String?
  country         String?
  postalCode      String?
  latitude        Float?
  longitude       Float?
  contactName     String?
  contactPosition String?
  contactNumber   String?
  email           String?
  companyId       Int
  company         Company        @relation(fields: [companyId], references: [id])
  departments     Department[]
  auditPrograms   AuditProgram[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String
  code        String?
  status      String?  @default("Active")
  manager     String?
  description String?
  siteId      Int
  site        Site     @relation(fields: [siteId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id                Int            @id @default(autoincrement())
  firstName         String
  lastName          String
  email             String         @unique
  mobile            String?
  role              String
  customRoleName    String?
  password          String
  isActive          Boolean        @default(true)
  auditPrograms      AuditProgram[] @relation("AuditorPrograms")
  leadAuditPrograms  AuditProgram[] @relation("LeadAuditor")
  auditPlans         AuditPlan[]    @relation("PlanAuditors")
  leadAuditPlans     AuditPlan[]    @relation("PlanLeadAuditor")
  creatorId          Int?
  creator            User?          @relation("UserCreator", fields: [creatorId], references: [id])
  createdUsers       User[]         @relation("UserCreator")
  companies          Company[]      @relation("UserCompanies")
  createdPrograms    AuditProgram[] @relation("UserAuditPrograms")
  createdPlans       AuditPlan[]    @relation("UserAuditPlans")
  createdAt          DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model AuditProgram {
  id            Int      @id @default(autoincrement())
  name          String
  isoStandard   String
  frequency     String
  duration      Int      @default(3)
  siteId        Int
  site          Site     @relation(fields: [siteId], references: [id])
  auditors      User[]   @relation("AuditorPrograms")
  leadAuditorId Int?
  leadAuditor   User?    @relation("LeadAuditor", fields: [leadAuditorId], references: [id])
  scheduleData  Json?    // Stores the grid/timeline data (selected clauses per period)
  status        String   @default("Draft")
  userId        Int?
  user          User?    @relation("UserAuditPrograms", fields: [userId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  auditPlans    AuditPlan[]
}

model AuditPlan {
  id             Int          @id @default(autoincrement())
  auditProgramId Int
  auditProgram   AuditProgram @relation(fields: [auditProgramId], references: [id])
  executionId    String       // Identifier like "FEB-2026" or unique combo to link to grid cell
  auditName      String?
  templateId     String?
  auditType      String?
  date           DateTime?
  location       String?
  scope          String?
  objective      String?
  criteria       String?
  leadAuditorId  Int?
  leadAuditor    User?        @relation("PlanLeadAuditor", fields: [leadAuditorId], references: [id])
  auditors       User[]       @relation("PlanAuditors")
  itinerary      Json?        // Stores array of {id, startTime, endTime, activity, notes}
  auditData      Json?        // Stores audit execution progress/results
  userId         Int?
  user           User?        @relation("UserAuditPlans", fields: [userId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([auditProgramId, executionId]) // Ensure one plan per execution slot
}
